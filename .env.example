VITE_ANTHROPIC_API_KEY=your-api-key-here

# Optional client override. Leave unset in local Vite dev to use the built-in /api proxy.
# Set this only when the frontend must call a separate backend origin directly.
VITE_API_URL=

# Server-side variables (no VITE_ prefix)
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-sandbox-secret
PLAID_ENV=sandbox

# Optional explicit OAuth redirect URI for Plaid Link.
# If omitted, the server will derive it from the request origin as /plaid-oauth.html.
PLAID_REDIRECT_URI=

# Neon Postgres
DATABASE_URL=postgresql://...

# AI (OpenRouter — primary: Qwen 3 235B free, fallback: Gemini 2.0 Flash)
OPENROUTER_API_KEY=sk-or-v1-...
AI_MODEL=qwen/qwen3-235b-a22b:free
AI_VISION_MODEL=google/gemini-2.0-flash-001

# Legacy Groq (still works as fallback if OPENROUTER_API_KEY is not set)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Auth0 (optional — leave blank to skip auth gate)
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=
AUTH0_BASE_URL=

# Vercel Blob (for file uploads)
BLOB_READ_WRITE_TOKEN=

# TinyFish (optional — for funding search)
TINYFISH_API_KEY=
